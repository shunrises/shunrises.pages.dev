---
import FilterPortfolio from "@/components/client/FilterPortfolio";
import portfolio_config from "@/portfolio-config.json";
import { parse } from "date-fns";
import { getImage } from "astro:assets";
import type { portfolioConfig } from "@/lib/types";
import type { ImageMetadata } from "astro";
import IndexHeader from "@/components/static/IndexHeader.astro";
import IndexLayout from "@/layouts/IndexLayout.astro";

const allItems = portfolio_config.sort((a, b) => {
    const dateA = parse(a.data.date, "dd-MM-yyyy", new Date());
    const dateB = parse(b.data.date, "dd-MM-yyyy", new Date());
    return dateB.getTime() - dateA.getTime();
});

type ImageRecord = { default: ImageMetadata };
const imageModules = import.meta.glob<ImageRecord>("@/assets/portfolio/*/*.{png,jpg,jpeg,webp,gif,avif}", { eager: true });

const enriched = await Promise.all(
    allItems.map(async (item) => {
        const matches = Object.entries(imageModules)
            .filter(([path]) => path.includes(`/assets/portfolio/${item.id}/`))
            .sort(([a], [b]) => a.localeCompare(b))
            .map(([, mod]) => mod.default);

        let heroImage: string | undefined;
        if (matches.length > 0) {
            const optimized = await getImage({ src: matches[0], width: 600 });
            heroImage = optimized.src;
        }

        return {
            ...item,
            ...item.data,
            keywords: item.data.tags,
            tagline: item.data.description,
            images: heroImage ? [heroImage] : [],
            heroImage,
        } as portfolioConfig & { heroImage?: string };
    }),
);
---

<IndexLayout title="portfolio - shunrises.dev" description="things i've made" image="/og/default.png">
    <div transition:animate="fade">
        <IndexHeader url="/" heading="Portfolio" />

        <div class="mt-3">
            <FilterPortfolio client:load items={enriched} />
        </div>
    </div>
</IndexLayout>
